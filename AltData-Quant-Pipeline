# Define the function that talks to Alpaca to actually buy the stock
def execute_trade(ticker: str, bet_size: float, current_price: float, atr_pct: float):
    """Sends the bracket order with dynamic sizing and hard stops to Alpaca."""
    try:
        # Calculate how many whole shares can be bought with the AI's dollar bet size (no fractional shares)
        qty = int(bet_size // current_price)
        
        # If the bet size is too small to even buy 1 share, abort the trade
        if qty <= 0:
            print(f"[{ticker}] Skipped: Calculated bet size (${bet_size:.2f}) cannot buy 1 full share.")
            return

        # Calculate the exact dollar price to place the stop-loss: Current Price minus (Current Price * ATR % * 1.5)
        stop_price = round(current_price * (1 - (atr_pct * ATR_MULTIPLIER)), 2)

        # Print the trade intent to the terminal
        print(f"[{ticker}] -> EXECUTING TRADE: Buying {qty} shares @ ~${current_price:.2f}. Hard Stop: ${stop_price:.2f}")

        # Build the Alpaca Market Order Request object
        order = MarketOrderRequest(
            symbol=ticker,                       # The stock to buy
            qty=qty,                             # The number of shares
            side=OrderSide.BUY,                  # Buy side
            time_in_force=TimeInForce.GTC,       # Good 'Til Canceled (the order stays active until filled)
            # Attach the hard stop-loss directly to the buy order as a bracket
            stop_loss=StopLossRequest(stop_price=stop_price)
        )

        # Fire the order request to Alpaca's servers
        submitted = trading_client.submit_order(order_data=order)
        
        # Print the official confirmation ID returned by the broker
        print(f"[{ticker}] -> SUCCESS! Alpaca Order ID: {submitted.id}")
        
    # Catch any API execution errors (e.g., insufficient buying power, market closed issues)
    except Exception as e:
        print(f"[{ticker}] -> EXECUTION FAILED: {e}")

