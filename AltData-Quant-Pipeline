# Define a function that takes a ticker symbol and returns its options data
def get_options_flow(ticker: str) -> dict:
    """Fetches live Options Flow data (P/C Ratio, Volume Shock, IV Rank) from Polygon.io."""

    # Wrap the network call in a try/except block so the script doesn't crash if the API goes down
    try:
        # Construct the specific URL to ping Polygon's options snapshot endpoint for the given ticker
        url = f"https://api.polygon.io/v3/snapshot/options/{ticker}?apiKey={OPTIONS_API_KEY}"
        
        # Send the GET request to Polygon and wait for the response
        response = requests.get(url)
        
        # Parse the text response into a Python dictionary (JSON)
        data = response.json()
        
        # Check if the API call failed (HTTP 200 means OK). If it failed, print the error and return safe baseline data
        if response.status_code != 200 or data.get("status") != "OK":
            print(f"[{ticker}] Options API Error: {data.get('error', 'Unknown Error')}")
            return {"Opt_Put_Call_Ratio": 1.0, "Opt_Call_Shock": 1.0, "Opt_IV_Rank": 50.0}

        # Extract the list of options contracts from the 'results' key in the JSON
        results = data.get("results", {})
       
        # If there are no options contracts available for this stock, return safe baseline data
        if not results:
            return {"Opt_Put_Call_Ratio": 1.0, "Opt_Call_Shock": 1.0, "Opt_IV_Rank": 50.0}

        # Create variables to keep a running total of Call volume, Put volume, and a list of Implied Volatilities
        call_vol = 0
        put_vol = 0
        current_iv_list = []
        
        # Loop through every single options contract returned by Polygon
        for contract in results:
            
            # Extract the specific details and today's trading data for the contract
            details = contract.get("details", {})
            day_data = contract.get("day", {})
            iv = contract.get("implied_volatility")
            
            # If the contract is a Call option, add its volume to our running Call total
            if details.get("contract_type") == "call":
                call_vol += day_data.get("volume", 0)
            
            # If the contract is a Put option, add its volume to our running Put total
            elif details.get("contract_type") == "put":
                put_vol += day_data.get("volume", 0)
                
            # If the contract has an Implied Volatility reading, append it to our list
            if iv:
                current_iv_list.append(iv)
                
        # Calculate the Put/Call ratio. Use max cap of 5.0 to handle extreme outliers or zero call volume
        p_c_ratio = min((put_vol / call_vol) if call_vol > 0 else 5.0, 5.0)
        
        # Set a hardcoded baseline for normal daily call volume (2,000) for small caps
        avg_expected_call_vol = 2000 
        
        # Calculate how much today's volume shocked the baseline (e.g., 2.0 means double the normal volume)
        call_shock = call_vol / avg_expected_call_vol if avg_expected_call_vol > 0 else 1.0
        
        # Calculate the average implied volatility across all contracts for this stock
        avg_iv = sum(current_iv_list) / len(current_iv_list) if current_iv_list else 0.50
        
        # Normalize the IV into a 0 to 100 scale, assuming 0.20 is the lowest historical and 1.20 is the highest
        iv_rank = ((avg_iv - 0.20) / (1.20 - 0.20)) * 100
       
        # Ensure the rank doesn't go below 0 or above 100
        iv_rank = min(max(iv_rank, 0.0), 100.0) 

        # Print the live institutional footprints to the terminal so the user can see what the AI sees
        print(f"[{ticker}] LIVE OPTIONS DATA -> Calls: {call_vol} | Puts: {put_vol} | P/C: {p_c_ratio:.2f}")

        # Return the engineered features back to the main script as a dictionary
        return {"Opt_Put_Call_Ratio": p_c_ratio, "Opt_Call_Shock": call_shock, "Opt_IV_Rank": iv_rank}

    # If literally anything else breaks (e.g., internet disconnects), catch the error, print it, and return safe baselines
    except Exception as e:
        print(f"[{ticker}] Failed to fetch real Options Flow: {e}")
        return {"Opt_Put_Call_Ratio": 1.0, "Opt_Call_Shock": 1.0, "Opt_IV_Rank": 50.0}

# Define a function to calculate technical chart data (ATR and Moving Averages)
def get_live_market_features(ticker: str):
    """Pulls recent price action to calculate ATR and Volume Shocks."""
    try:
        # Download 1 month of daily stock price data from Yahoo Finance silently
        df = yf.download(ticker, period="1mo", progress=False)
        
        # If Yahoo returns nothing, exit the function
        if df.empty:
            return None
            
        # Clean up the dataframe columns if Yahoo returns a multi-level index format
        if isinstance(df.columns, pd.MultiIndex):
            df.columns = df.columns.get_level_values(0)
            
        # Download 5 days of the VIX (Fear Index)
        df_vix = yf.download("^VIX", period="5d", progress=False)
        # Extract the very last closing price of the VIX, default to 20.0 if it fails
        current_vix = df_vix['Close'].iloc[-1].item() if not df_vix.empty else 20.0
        
        # Calculate the three components of True Range: High minus Low
        df['H_L'] = df['High'] - df['Low']
        
        # Absolute value of High minus the previous day's Close
        df['H_PC'] = abs(df['High'] - df['Close'].shift(1))
        
        # Absolute value of Low minus the previous day's Close
        df['L_PC'] = abs(df['Low'] - df['Close'].shift(1))
        
        # Find the maximum of those three values to get today's True Range
        df['True_Range'] = df[['H_L', 'H_PC', 'L_PC']].max(axis=1)
        
        # Get the most recent closing price of the stock
        current_price = float(df['Close'].iloc[-1])
        
        # Calculate the 14-day rolling average of the True Range (the ATR) and grab the final value
        atr_14 = df['True_Range'].rolling(14).mean().iloc[-1]
        
        # Convert the dollar ATR into a percentage of the current stock price
        atr_pct = float(atr_14 / current_price)
        
        # Calculate the 10-day Simple Moving Average
        ma_10 = df['Close'].rolling(10).mean().iloc[-1]
        
        # Calculate the 30-day Simple Moving Average
        ma_30 = df['Close'].rolling(30).mean().iloc[-1]
        
        # Create a binary signal: 1 if the short-term trend is above the long-term trend, 0 otherwise
        base_signal_active = 1 if ma_10 > ma_30 else 0
        
        # Return all the calculated technical metrics as a dictionary
        return {
            "Current_Price": current_price,
            "ATR_Pct": atr_pct,
            "VIX_Fear_Index": float(current_vix),
            "Base_Signal_Active": base_signal_active
        }
    # Catch any data downloading or math errors and return None
    except Exception as e:
        print(f"[{ticker}] YFinance Error: {e}")
        return None

