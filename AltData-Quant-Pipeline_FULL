import yfinance as yf

import pandas as pd

import numpy as np

import xgboost as xgb

from sklearn.model_selection import TimeSeriesSplit

import warnings


warnings.filterwarnings('ignore')


# ==========================================

# 1. BACKTEST CONFIGURATION

# ==========================================

HOLD_DAYS = 5

ATR_MULTIPLIER = 1.5

MIN_EV_THRESHOLD = 0.10  # Keeping the stricter threshold

START_DATE = "2021-01-01"

END_DATE = "2024-01-01"


TICKERS = [

    "RIOT", "MARA", "PLUG", "FCEL", "RUN", 

    "AMSC", "PACB", "EDIT", "CRSP", "GPRO", 

    "GOLF", "YELP", "EXTR", "AGYS", "PRTS", 

    "BKE", "SAH", "RICK", "WNC", "GATX", 

    "AAON", "MTH", "LGIH", "WASH", "BANF",

    "UPST", "SOFI", "PLTR", "AFRM", "HOOD",  

    "AMC", "GME", "BYND", "CVNA", "SPCE",    

    "QS", "LCID", "CHPT", "BLNK", "MVIS",    

    "DKNG", "PENN", "FUBO", "OPEN", "SOUN",  

    "RKLB", "IONQ", "ROOT", "LMND", "AI"     

]


# ==========================================

# 2. THE CUSTOM ASYMMETRIC LOSS FUNCTION

# ==========================================

def fat_tail_objective(y_true, y_pred):

    residual = y_pred - y_true

    grad = residual

    hess = np.ones_like(y_true)

    

    fat_tail_mask = (y_true > 0.10) & (residual < 0)

    

    # Tuned Penalty

    penalty_multiplier = 15.0

    grad[fat_tail_mask] *= penalty_multiplier

    hess[fat_tail_mask] *= penalty_multiplier

    

    return grad, hess


# ==========================================

# 3. HISTORICAL DATA INGESTION & FEATURE ENGINEERING

# ==========================================

def build_historical_dataset(tickers):

    print("Downloading Historical Data and Engineering Features...")

    all_data = []

    

    for ticker in tickers:

        df = yf.download(ticker, start=START_DATE, end=END_DATE, progress=False)

        if df.empty:

            continue

            

        if isinstance(df.columns, pd.MultiIndex):

            df.columns = df.columns.get_level_values(0)

            

        # 1. Technical & Volatility Features

        df['H_L'] = df['High'] - df['Low']

        df['H_PC'] = abs(df['High'] - df['Close'].shift(1))

        df['L_PC'] = abs(df['Low'] - df['Close'].shift(1))

        df['True_Range'] = df[['H_L', 'H_PC', 'L_PC']].max(axis=1)

        df['ATR_14'] = df['True_Range'].rolling(14).mean()

        df['ATR_Pct'] = df['ATR_14'] / df['Close']

        

        # 2. Proxy Alternative Data (Volume Velocity Shocks)

        df['Avg_Vol_30'] = df['Volume'].rolling(30).mean()

        df['Volume_Shock'] = df['Volume'] / df['Avg_Vol_30']

        

        # 3. THE REGIME FILTER (New)

        df['MA_30'] = df['Close'].rolling(30).mean()

        # Binary flag: 1 if in an uptrend, 0 if in a downtrend

        df['Trend_Active'] = np.where(df['Close'] > df['MA_30'], 1, 0)

        

        # 4. The Target Variable (The Future)

        df['Future_Close_5d'] = df['Close'].shift(-HOLD_DAYS)

        df['Future_5d_Low'] = df['Low'].rolling(window=HOLD_DAYS).min().shift(-HOLD_DAYS)

        df['Target_Return'] = (df['Future_Close_5d'] - df['Close']) / df['Close']

        

        df = df.dropna()

        df['Ticker'] = ticker

        

        all_data.append(df)

        

    return pd.concat(all_data)


# ==========================================

# 4. WALK-FORWARD BACKTEST ENGINE

