# Backtest-Optimized Risk Parameters

HOLD_DAYS = 5

ATR_MULTIPLIER = 1.5        

MIN_AI_BET = 500            

MAX_AI_BET = 2500           

MIN_EV_THRESHOLD = 0.10     # UPDATED: Increased to 10% to prevent overtrading

MAX_EV_CAP = 0.20           # Scaled up to match the stricter entry threshold


# Expanded 50-Ticker Basket (High Volatility / Options Heavy)

TICKERS = [

    # Original 25

